{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Compare Multiple ASR Evaluation Runs\n",
    "\n",
    "This notebook allows you to compare results from multiple evaluation runs with different configurations or parameters.\n",
    "\n",
    "## Features:\n",
    "- Load and compare multiple run results\n",
    "- Visualize performance across runs\n",
    "- Analyze parameter effects\n",
    "- Generate comparison reports\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Multiple Run Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import json\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pathlib import Path\n",
    "from datetime import datetime\n",
    "import glob\n",
    "\n",
    "# Set up plotting style\n",
    "plt.style.use('seaborn-v0_8')\n",
    "sns.set_palette(\"husl\")\n",
    "\n",
    "print(\"🔍 Looking for previous runs...\")\n",
    "\n",
    "# Find all run directories\n",
    "results_dir = Path(\"results/comparisons\")\n",
    "run_dirs = [d for d in results_dir.iterdir() if d.is_dir() and d.name.startswith(\"run_\")]\n",
    "run_dirs.sort(reverse=True)  # Most recent first\n",
    "\n",
    "print(f\"Found {len(run_dirs)} previous runs:\")\n",
    "for i, run_dir in enumerate(run_dirs):\n",
    "    print(f\"  {i+1}. {run_dir.name}\")\n",
    "\n",
    "if len(run_dirs) == 0:\n",
    "    print(\"❌ No previous runs found. Please run the main evaluation notebook first.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Select Runs to Compare"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Select runs to compare (modify as needed)\n",
    "# Options: \n",
    # - Use all runs: selected_runs = run_dirs\n",
    "# - Use specific runs: selected_runs = [run_dirs[0], run_dirs[1]]\n",
    "# - Use N most recent: selected_runs = run_dirs[:3]\n",
    "\n",
    "# Example: Compare the 3 most recent runs\n",
    "selected_runs = run_dirs[:3] if len(run_dirs) >= 3 else run_dirs\n",
    "\n",
    "print(f\"\\n📊 Selected {len(selected_runs)} runs for comparison:\")\n",
    "for run_dir in selected_runs:\n",
    "    print(f\"  - {run_dir.name}\")\n",
    "\n",
    "# Load results from selected runs\n",
    "all_results = []\n",
    "run_configs = {}\n",
    "\n",
    "for run_dir in selected_runs:\n",
    "    # Load run metadata\n",
    "    metadata_file = run_dir / f\"run_metadata_{run_dir.name.replace('run_', '')}.json\"\n",
    "    \n",
    "    if metadata_file.exists():\n",
    "        with open(metadata_file, 'r', encoding='utf-8') as f:\n",
    "            metadata = json.load(f)\n",
    "        \n",
    "        run_configs[run_dir.name] = metadata\n",
    "        \n",
    "        # Load results\n",
    "        results_file = run_dir / f\"asr_compare_{metadata['run_id']}.json\"\n",
    "        if results_file.exists():\n",
    "            with open(results_file, 'r', encoding='utf-8') as f:\n",
    "                run_results = json.load(f)\n",
    "            \n",
    "            # Add run information to each result\n",
    "            for result in run_results:\n",
    "                result['run_name'] = run_dir.name\n",
    "                result['run_timestamp'] = metadata['timestamp']\n",
    "                result['run_config'] = metadata.get('config', {})\n",
    "            \n",
    "            all_results.extend(run_results)\n",
    "            print(f\"  ✅ Loaded {len(run_results)} results from {run_dir.name}\")\n",
    "        else:\n",
    "            print(f\"  ❌ Results file not found for {run_dir.name}\")\n",
    "    else:\n",
    "        print(f\"  ❌ Metadata file not found for {run_dir.name}\")\n",
    "\n",
    "print(f\"\\n📈 Total results loaded: {len(all_results)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Overview Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if all_results:\n",
    "    # Create comparison dataframe\n",
    "    df = pd.DataFrame(all_results)\n",
    "    \n",
    "    # Display run configurations\n",
    "    print(\"\\n🔧 Run Configurations:\")\n",
    "    for run_name, config in run_configs.items():\n",
    "        print(f\"\\n{run_name}:\")\n",
    "        key_params = ['min_elongated_sec', 'shorten_factor', 'models_to_eval', 'run_timestamp']\n",
    "        for param in key_params:\n",
    "            if param in config.get('config', {}):\n",
    "                print(f\"  {param}: {config['config'][param]}\")\n",
    "    \n",
    "    # Summary table\n",
    "    print(\"\\n📊 Performance Summary:\")\n",
    "    summary_cols = ['run_name', 'model', 'condition', 'cer', 'substitution_rate', 'insertion_rate', 'deletion_rate']\n",
    "    summary_df = df[summary_cols].round(4)\n",
    "    \n",
    "    # Sort by run and model\n",
    "    summary_df = summary_df.sort_values(['run_name', 'model', 'condition'])\n",
    "    \n",
    "    print(summary_df.to_string(index=False))\n",
    "    \n",
    "else:\n",
    "    print(\"❌ No results to compare\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Visual Comparison Across Runs"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if all_results:\n",
    "    df = pd.DataFrame(all_results)\n",
    "    \n",
    "    # Create comprehensive comparison plots\n",
    "    fig, axes = plt.subplots(2, 3, figsize=(18, 12))\n",
    "    fig.suptitle('ASR Performance Comparison Across Multiple Runs', fontsize=16, fontweight='bold')\n",
    "    \n",
    "    # 1. CER by Model and Run\n",
    "    ax1 = axes[0, 0]\n",
    "    pivot_cer = df.pivot_table(values='cer', index='run_name', columns='model', aggfunc='mean')\n",
    "    pivot_cer.plot(kind='bar', ax=ax1, width=0.8)\n",
    "    ax1.set_title('CER by Model and Run')\n",
    "    ax1.set_ylabel('Character Error Rate')\n",
    "    ax1.legend(title='Model', bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "    ax1.tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # 2. Original vs Shortened Comparison\n",
    "    ax2 = axes[0, 1]\n",
    "    condition_pivot = df.pivot_table(values='cer', index='run_name', columns='condition', aggfunc='mean')\n",
    "    condition_pivot.plot(kind='bar', ax=ax2, width=0.8)\n",
    "    ax2.set_title('Original vs Shortened Audio')\n",
    "    ax2.set_ylabel('CER')\n",
    "    ax2.legend(title='Condition')\n",
    "    ax2.tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # 3. Error Type Comparison\n",
    "    ax3 = axes[0, 2]\n",
    "    error_types = ['substitution_rate', 'insertion_rate', 'deletion_rate']\n",
    "    error_summary = df.groupby('run_name')[error_types].mean()\n",
    "    error_summary.plot(kind='bar', ax=ax3, stacked=True)\n",
    "    ax3.set_title('Error Type Distribution by Run')\n",
    "    ax3.set_ylabel('Error Rate')\n",
    "    ax3.legend(title='Error Type')\n",
    "    ax3.tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # 4. Model Performance Trend\n",
    "    ax4 = axes[1, 0]\n",
    "    # Sort runs by timestamp\n",
    "    df_sorted = df.copy()\n",
    "    df_sorted['run_datetime'] = pd.to_datetime(df_sorted['run_timestamp'])\n",
    "    df_sorted = df_sorted.sort_values('run_datetime')\n",
    "    \n",
    "    for model in df_sorted['model'].unique():\n",
    "        model_data = df_sorted[df_sorted['model'] == model]\n",
    "        model_avg = model_data.groupby('run_name')['cer'].mean().reset_index()\n",
    "        model_avg = model_avg.merge(df_sorted[['run_name', 'run_datetime']].drop_duplicates(), on='run_name')\n",
    "        model_avg = model_avg.sort_values('run_datetime')\n",
    "        ax4.plot(range(len(model_avg)), model_avg['cer'], marker='o', label=model, linewidth=2)\n",
    "    \n",
    "    ax4.set_title('Model Performance Trend Over Time')\n",
    "    ax4.set_ylabel('CER')\n",
    "    ax4.set_xlabel('Run Sequence')\n",
    "    ax4.legend(title='Model')\n",
    "    ax4.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 5. Robustness Score Comparison\n",
    "    ax5 = axes[1, 1]\n",
    "    robustness_scores = []\n",
    "    for run_name in df['run_name'].unique():\n",
    "        run_data = df[df['run_name'] == run_name]\n",
    "        for model in run_data['model'].unique():\n",
    "            model_data = run_data[run_data['model'] == model]\n",
    "            orig_data = model_data[model_data['condition'] == 'original']\n",
    "            short_data = model_data[model_data['condition'] == 'shortened']\n",
    "            \n",
    "            if len(orig_data) > 0 and len(short_data) > 0:\n",
    "                orig_cer = orig_data['cer'].iloc[0]\n",
    "                short_cer = short_data['cer'].iloc[0]\n",
    "                robustness = abs(short_cer - orig_cer) / orig_cer\n",
    "                robustness_scores.append({\n",
    "                    'run_name': run_name,\n",
    "                    'model': model,\n",
    "                    'robustness_score': robustness\n",
    "                })\n",
    "    \n",
    "    if robustness_scores:\n",
    "        robust_df = pd.DataFrame(robustness_scores)\n",
    "        robust_pivot = robust_df.pivot_table(values='robustness_score', index='run_name', columns='model')\n",
    "        robust_pivot.plot(kind='bar', ax=ax5, width=0.8)\n",
    "        ax5.set_title('Robustness Score (Lower = More Robust)')\n",
    "        ax5.set_ylabel('Robustness Score')\n",
    "        ax5.legend(title='Model', bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "        ax5.tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # 6. Parameter Impact Analysis\n",
    "    ax6 = axes[1, 2]\n",
    "    # Analyze impact of key parameters\n",
    "    param_impact = []\n",
    "    for run_name, config in run_configs.items():\n",
    "        run_data = df[df['run_name'] == run_name]\n",
    "        avg_cer = run_data['cer'].mean()\n",
    "        \n",
    "        param_impact.append({\n",
    "            'run_name': run_name,\n",
    "            'avg_cer': avg_cer,\n",
    "            'shorten_factor': config.get('config', {}).get('shorten_factor', 0.75),\n",
    "            'min_elongated_sec': config.get('config', {}).get('min_elongated_sec', 0.5)\n",
    "        })\n",
    "    \n",
    "    param_df = pd.DataFrame(param_impact)\n",
    "    scatter = ax6.scatter(param_df['shorten_factor'], param_df['avg_cer'], \n",
    "                       s=100, alpha=0.7, c=range(len(param_df)), cmap='viridis')\n",
    "    ax6.set_xlabel('Shorten Factor')\n",
    "    ax6.set_ylabel('Average CER')\n",
    "    ax6.set_title('Parameter Impact: Shorten Factor vs CER')\n",
    "    ax6.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Add run labels to scatter plot\n",
    "    for i, row in param_df.iterrows():\n",
    "        ax6.annotate(row['run_name'].replace('run_', ''), \n",
    "                   (row['shorten_factor'], row['avg_cer']), \n",
    "                   xytext=(5, 5), textcoords='offset points', fontsize=8)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    # Save comparison plots\n",
    "    comparison_plot_path = f\"results/multi_run_comparisons/comparison_plots_{datetime.now().strftime('%Y%m%d_%H%M%S')}.png\"\n",
    "    plt.savefig(comparison_plot_path, dpi=300, bbox_inches='tight')\n",
    "    print(f\"📊 Comparison plots saved to: {comparison_plot_path}\")\n",
    "\nelse:\n",
    "    print(\"❌ No results to visualize\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Detailed Analysis and Insights"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if all_results:\n",
    "    df = pd.DataFrame(all_results)\n",
    "    \n",
    "    print(\"\\n🔍 Detailed Analysis:\")\n",
    "    \n",
    "    # Best performing configurations\n",
    "    print(\"\\n🏆 Best Performing Configurations:\")\n",
    "    best_overall = df.loc[df['cer'].idxmin()]\n",
    "    print(f\"  Best overall: {best_overall['model']} on {best_overall['condition']} in {best_overall['run_name']}\")\n",
    "    print(f\"  CER: {best_overall['cer']:.4f}\")\n",
    "    \n",
    "    # Best by model\n",
    "    print(\"\\n🎯 Best by Model:\")\n",
    "    for model in df['model'].unique():\n",
    "        model_best = df[df['model'] == model].loc[df[df['model'] == model]['cer'].idxmin()]\n",
    "        print(f\"  {model}: CER {model_best['cer']:.4f} ({model_best['condition']} in {model_best['run_name']})\")\n",
    "    \n",
    "    # Most robust models\n",
    "    print(\"\\n🛡️ Most Robust Models (lowest sensitivity to audio modification):\")\n",
    "    robustness_analysis = []\n",
    "    for run_name in df['run_name'].unique():\n",
    "        run_data = df[df['run_name'] == run_name]\n",
    "        for model in run_data['model'].unique():\n",
    "            model_data = run_data[run_data['model'] == model]\n",
    "            orig_data = model_data[model_data['condition'] == 'original']\n",
    "            short_data = model_data[model_data['condition'] == 'shortened']\n",
    "            \n",
    "            if len(orig_data) > 0 and len(short_data) > 0:\n",
    "                orig_cer = orig_data['cer'].iloc[0]\n",
    "                short_cer = short_data['cer'].iloc[0]\n",
    "                robustness = abs(short_cer - orig_cer) / orig_cer\n",
    "                robustness_analysis.append({\n",
    "                    'run_name': run_name,\n",
    "                    'model': model,\n",
    "                    'robustness_score': robustness,\n",
    "                    'cer_change': short_cer - orig_cer,\n",
    "                    'cer_change_pct': ((short_cer - orig_cer) / orig_cer * 100)\n",
    "                })\n",
    "    \n",
    "    if robustness_analysis:\n",
    "        robust_df = pd.DataFrame(robustness_analysis)\n",
    "        most_robust = robust_df.loc[robust_df['robustness_score'].idxmin()]\n",
    "        print(f\"  Most robust: {most_robust['model']} in {most_robust['run_name']}\")\n",
    "        print(f\"  Robustness score: {most_robust['robustness_score']:.4f}\")\n",
    "        print(f\"  CER change: {most_robust['cer_change_pct']:.2f}%\")\n",
    "    \n",
    "    # Parameter effects\n",
    "    print(\"\\n⚙️ Parameter Effects Analysis:\")\n",
    "    param_effects = []\n",
    "    for run_name, config in run_configs.items():\n",
    "        run_data = df[df['run_name'] == run_name]\n",
    "        avg_cer = run_data['cer'].mean()\n",
    "        \n",
    "        param_effects.append({\n",
    "            'run_name': run_name,\n",
    "            'avg_cer': avg_cer,\n",
    "            'shorten_factor': config.get('config', {}).get('shorten_factor', 0.75),\n",
    "            'min_elongated_sec': config.get('config', {}).get('min_elongated_sec', 0.5)\n",
    "        })\n",
    "    \n",
    "    param_df = pd.DataFrame(param_effects)\n",
    "    if len(param_df) > 1:\n",
    "        # Correlation analysis\n",
    "        corr_shorten = param_df['shorten_factor'].corr(param_df['avg_cer'])\n",
    "        corr_min_elong = param_df['min_elongated_sec'].corr(param_df['avg_cer'])\n",
    "        \n",
    "        print(f\"  Shorten factor correlation with CER: {corr_shorten:.3f}\")\n",
    "        print(f\"  Min elongated seconds correlation with CER: {corr_min_elong:.3f}\")\n",
    "        \n",
    "        if abs(corr_shorten) > 0.5:\n",
    "            trend = \"positive\" if corr_shorten > 0 else \"negative\"\n",
    "            print(f\"  → Strong {trend} correlation between shorten factor and CER\")\n",
    "        \n",
    "        if abs(corr_min_elong) > 0.5:\n",
    "            trend = \"positive\" if corr_min_elong > 0 else \"negative\"\n",
    "            print(f\"  → Strong {trend} correlation between min elongated seconds and CER\")\n",
    "\nelse:\n",
    "    print(\"❌ No results to analyze\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Export Comparison Report"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if all_results:\n",
    "    # Create comprehensive comparison report\n",
    "    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')\n",
    "    \n",
    "    comparison_report = {\n",
    "        \"comparison_timestamp\": datetime.now().isoformat(),\n",
    "        \"runs_compared\": [run.name for run in selected_runs],\n",
    "        \"total_results\": len(all_results),\n",
    "        \"run_configurations\": run_configs,\n",
    "        \"all_results\": all_results,\n",
    "        \"analysis_summary\": {\n",
    "            \"best_overall\": {\n",
    "                \"model\": best_overall['model'],\n",
    "                \"condition\": best_overall['condition'],\n",
    "                \"run_name\": best_overall['run_name'],\n",
    "                \"cer\": best_overall['cer']\n",
    "            } if 'best_overall' in locals() else None,\n",
    "            \"most_robust\": {\n",
    "                \"model\": most_robust['model'],\n",
    "                \"run_name\": most_robust['run_name'],\n",
    "                \"robustness_score\": most_robust['robustness_score'],\n",
    "                \"cer_change_pct\": most_robust['cer_change_pct']\n",
    "            } if 'most_robust' in locals() else None\n",
    "        }\n",
    "    }\n",
    "    \n",
    "    # Save comparison report\n",
    "    report_path = f\"results/multi_run_comparisons/comparison_report_{timestamp}.json\"\n",
    "    \n",
    "    with open(report_path, 'w', encoding='utf-8') as f:\n",
    "        json.dump(comparison_report, f, ensure_ascii=False, indent=2)\n",
    "    \n",
    "    # Save CSV summary\n",
    "    summary_df = pd.DataFrame(all_results)[\n",
    "        ['run_name', 'run_timestamp', 'model', 'condition', 'cer', \n",
    "         'substitution_rate', 'insertion_rate', 'deletion_rate']\n",
    "    ]\n",
    "    \n",
    "    csv_path = f\"results/multi_run_comparisons/comparison_summary_{timestamp}.csv\"\n",
    "    summary_df.to_csv(csv_path, index=False)\n",
    "    \n",
    "    print(f\"\\n📋 Comparison Report Generated:\")\n",
    "    print(f\"  📄 JSON Report: {report_path}\")\n",
    "    print(f\"  📊 CSV Summary: {csv_path}\")\n",
    "    print(f\"  📈 Plots: {comparison_plot_path if 'comparison_plot_path' in locals() else 'Not generated'}\")\n",
    "    \n",
    "    # Create summary text file\n",
    "    summary_text = f\"\"\"\n",
    "ASR Multi-Run Comparison Report\n",
    "Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n",
    "========================================\n",
    "\n",
    "Runs Compared: {len(selected_runs)}\n",
    "Total Results: {len(all_results)}\n",
    "\n",
    "Runs:\n",
    "{chr(10).join([f'  - {run.name}' for run in selected_runs])}\n",
    "\n",
    "Best Overall Performance:\n",
    "  Model: {best_overall['model'] if 'best_overall' in locals() else 'N/A'}\n",
    "  Condition: {best_overall['condition'] if 'best_overall' in locals() else 'N/A'}\n",
    "  Run: {best_overall['run_name'] if 'best_overall' in locals() else 'N/A'}\n",
    "  CER: {best_overall['cer']:.4f if 'best_overall' in locals() else 'N/A'}\n",
    "\n",
    "Most Robust Model:\n",
    "  Model: {most_robust['model'] if 'most_robust' in locals() else 'N/A'}\n",
    "  Run: {most_robust['run_name'] if 'most_robust' in locals() else 'N/A'}\n",
    "  Robustness Score: {most_robust['robustness_score']:.4f if 'most_robust' in locals() else 'N/A'}\n",
    "  CER Change: {most_robust['cer_change_pct']:.2f}% if 'most_robust' in locals() else 'N/A'}\n",
    "\n",
    "Files Generated:\n",
    "  - {report_path}\n",
    "  - {csv_path}\n",
    "  - {comparison_plot_path if 'comparison_plot_path' in locals() else 'No plots'}\n",
    "\"\"\"\n",
    "    \n",
    "    text_path = f\"results/multi_run_comparisons/comparison_summary_{timestamp}.txt\"\n",
    "    with open(text_path, 'w', encoding='utf-8') as f:\n",
    "        f.write(summary_text)\n",
    "    \n",
    "    print(f\"  📝 Text Summary: {text_path}\")\n",
    "    print(f\"\\n✨ Comparison complete! Check {Path('results/multi_run_comparisons').absolute()} for all files.\")\n",
    "\nelse:\n",
    "    print(\"❌ No results to export\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Usage Instructions\n",
    "\n",
    "### How to Use This Notebook:\n",
    "\n",
